---
interface Props {
  filterKey: string;
  label: string;
  tooltip?: string;
  icon?: string;
}
const { filterKey, label, tooltip, icon = "★" } = Astro.props;
---

<div class="filter-field" data-tooltip={tooltip}>
  <label class="filter-label">{label}</label>
  <button
    type="button"
    class="bool-toggle"
    data-bool-key={filterKey}
    aria-pressed="false"
  >
    <span class="bool-toggle-icon" aria-hidden="true">{icon}</span>
    <span class="bool-toggle-label">All</span>
  </button>
</div>

<style>
  .filter-field {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .filter-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--foreground) 40%, transparent);
  }
  .filter-field[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: normal;
    max-width: 220px;
    width: max-content;
    background-color: var(--foreground);
    color: var(--background);
    font-size: 0.7rem;
    line-height: 1.4;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 10;
  }
  .filter-field[data-tooltip]:hover::after {
    opacity: 1;
  }
  .bool-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    width: 100%;
    padding: 0.275rem 0.625rem;
    border-radius: 0.5rem;
    background: var(--muted);
    border: 1px solid transparent;
    color: color-mix(in srgb, var(--foreground) 60%, transparent);
    font-size: 0.75rem;
    cursor: pointer;
    transition:
      background-color 0.15s,
      color 0.15s,
      border-color 0.15s;
  }
  .bool-toggle:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
  }
  .bool-toggle[data-active] {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .bool-toggle-icon {
    font-size: 0.9rem;
    line-height: 1;
  }
  .bool-toggle[data-active] .bool-toggle-icon {
    filter: drop-shadow(
      0 0 3px color-mix(in srgb, var(--accent) 60%, transparent)
    );
  }
</style>
