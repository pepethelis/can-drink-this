---
import { getCollection } from "astro:content";
import { slugifyTagPath } from "@/utils/slugify";
import postFilter from "@/utils/postFilter";
import type { BrandGroup } from "@/types/reviews";

type Props = {
  showToc?: boolean;
  tocItems?: { depth: number; slug: string; text: string }[];
};

const { showToc = false, tocItems = [] } = Astro.props;

const reviews = await getCollection("reviews", ({ data }) =>
  postFilter({ data })
);
const tagCounts = new Map<
  string,
  { tag: string; tagName: string; count: number }
>();

for (const review of reviews) {
  for (const tagName of review.data.tags ?? []) {
    const tag = slugifyTagPath(tagName);
    const current = tagCounts.get(tag);
    if (current) {
      current.count += 1;
    } else {
      tagCounts.set(tag, { tag, tagName, count: 1 });
    }
  }
}

const categoryCounts = new Map<string, number>();
for (const review of reviews) {
  const cat = review.data.category;
  categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1);
}
const categories = Array.from(categoryCounts.entries()).sort(
  (a, b) => b[1] - a[1]
);

const typeCounts = new Map<string, number>();
for (const review of reviews)
  for (const t of review.data.types ?? [])
    typeCounts.set(t, (typeCounts.get(t) ?? 0) + 1);
const types = Array.from(typeCounts.entries()).sort((a, b) => b[1] - a[1]);

const brandGroupMap = new Map<string, BrandGroup>();
for (const review of reviews) {
  const brand = review.data.brand;
  if (!brand) continue;
  const slashIdx = brand.indexOf("/");
  const base = slashIdx === -1 ? brand : brand.slice(0, slashIdx);
  const sub = slashIdx === -1 ? null : brand.slice(slashIdx + 1);
  const group = brandGroupMap.get(base) ?? { base, total: 0, subs: [] };
  group.total++;
  if (sub) {
    const existing = group.subs.find(s => s.name === sub);
    if (existing) existing.count++;
    else group.subs.push({ name: sub, count: 1 });
  }
  brandGroupMap.set(base, group);
}
const brandGroups = Array.from(brandGroupMap.values())
  .sort((a, b) => a.base.localeCompare(b.base))
  .map(g => ({ ...g, subs: g.subs.sort((a, b) => a.name.localeCompare(b.name)) }));

const sponsorMap = new Map<string, number>();
for (const review of reviews)
  for (const s of review.data.sponsor ?? [])
    sponsorMap.set(s, (sponsorMap.get(s) ?? 0) + 1);
const sponsors = Array.from(sponsorMap.entries()).sort((a, b) => b[1] - a[1]);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const reviewsUrl = `${base}/reviews`;

const chipClass =
  "inline-flex items-center gap-1 rounded-full bg-muted px-2.5 py-0.5 text-xs text-foreground/80 hover:bg-accent hover:text-background transition-colors";
const subChipClass =
  "inline-flex items-center gap-1 rounded-full bg-muted/60 px-2 py-0.5 text-xs text-foreground/60 hover:bg-accent hover:text-background transition-colors";
---

<aside
  class="right-panel fixed top-0 right-6 hidden h-full max-h-full w-64 border-l pt-4 lg:border-border xl:block"
>
  <div class="flex flex-col gap-2  max-h-full overflow-auto">
    {
      showToc && tocItems.length > 0 && (
        <section class="rounded bg-background/80 p-4 backdrop-blur">
          <h2 class="text-xs font-semibold tracking-widest text-foreground/80 uppercase">
            On this page
          </h2>
          <nav class="mt-3 max-h-96 overflow-auto text-sm">
            <ol class="space-y-2">
              {tocItems.map(item => (
                <li
                  class:list={[
                    item.depth !== 1 && "pl-2",
                    item.depth === 2 && "",
                    item.depth === 3 && "ml-2 border-l border-border",
                    item.depth === 4 && "ml-4 border-l border-border",
                  ]}
                >
                  <a
                    href={`#${item.slug}`}
                    class="block text-foreground/80 hover:text-accent focus-visible:no-underline"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </section>
      )
    }

    <section class="rounded bg-background/80 p-4 backdrop-blur">
      <h2 class="text-xs font-semibold tracking-widest text-foreground/80 uppercase">
        Categories
      </h2>
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {
          categories.map(([name, count]) => (
            <li>
              <a
                href={`${reviewsUrl}?category=${encodeURIComponent(name)}`}
                class={chipClass}
              >
                {name}
                <span class="text-foreground/40">{count}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    {
      sponsors.length > 0 && (
        <section class="rounded bg-background/80 p-4 backdrop-blur">
          <h2 class="text-xs font-semibold tracking-widest text-foreground/80 uppercase">
            Sponsors
          </h2>
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {sponsors.map(([name, count]) => (
              <li>
                <a
                  href={`${reviewsUrl}?sponsor=${encodeURIComponent(name)}`}
                  class={chipClass}
                >
                  {name}
                  <span class="text-foreground/40">{count}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="rounded bg-background/80 p-4 backdrop-blur">
      <h2 class="text-xs font-semibold tracking-widest text-foreground/80 uppercase">
        Types
      </h2>
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {
          types.map(([name, count]) => (
            <li>
              <a
                href={`${reviewsUrl}?type=${encodeURIComponent(name)}`}
                class={chipClass}
              >
                {name}
                <span class="text-foreground/40">{count}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="rounded bg-background/80 p-4 backdrop-blur">
      <h2 class="text-xs font-semibold tracking-widest text-foreground/80 uppercase">
        Brands
      </h2>
      <ul class="mt-3 flex flex-wrap gap-2">
        {
          brandGroups.map(group => (
            <li class="flex flex-wrap items-center gap-1">
              <a
                href={`${reviewsUrl}?brand=${encodeURIComponent(group.base)}`}
                class={chipClass}
              >
                {group.base}
                <span class="text-foreground/40">{group.total}</span>
              </a>
              {group.subs.map(sub => (
                <a
                  href={`${reviewsUrl}?brand=${encodeURIComponent(`${group.base}/${sub.name}`)}`}
                  class={subChipClass}
                >
                  {sub.name}
                  <span class="text-foreground/40">{sub.count}</span>
                </a>
              ))}
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</aside>
