---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
const tagParts = tagName.split("/").filter(Boolean);
const tagPathParts = tag.split("/").filter(Boolean);

const collapseSlashes = (value: string) => value.replace(/\/{2,}/g, "/");
const tagHref = collapseSlashes(`/${import.meta.env.BASE_URL}/tags/${tag}`);
const tagSegmentHrefs = tagPathParts.map((_, index) =>
  collapseSlashes(
    `/${import.meta.env.BASE_URL}/tags/${tagPathParts.slice(0, index + 1).join("/")}`
  )
);
---

<li>
  <span
    class:list={[
      "flex items-center gap-0.5",
      "border-b-2 border-dashed border-foreground",
      "hover:border-accent hover:text-accent",
      "focus-visible:border-none focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {
      tagParts.length > 0 ? (
        tagParts.map((name, index) => (
          <>
            {index > 0 && <span class="mx-1 opacity-70">/</span>}
            <a
              href={tagSegmentHrefs[index]}
              class="hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
              transition:name={tagPathParts.slice(0, index + 1).join("/")}
            >
              <span>{name}</span>
            </a>
          </>
        ))
      ) : (
        <a
          href={tagHref}
          class="hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
          transition:name={tag}
        >
          <span>{tagName}</span>
        </a>
      )
    }
  </span>
</li>
