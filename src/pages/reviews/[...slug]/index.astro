---
import { type CollectionEntry, getCollection } from "astro:content";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import ReviewDetails from "@/layouts/ReviewDetails.astro";
import postFilter from "@/utils/postFilter";

type Props = {
  post: CollectionEntry<"reviews">;
};

export async function getStaticPaths() {
  const posts = await getCollection("reviews", ({ data }) =>
    postFilter({ data })
  );
  const postResult = posts.map(post => ({
    params: {
      slug: getPath(post.id, post.filePath, false),
    },
    props: { post },
  }));

  return postResult;
}

const { post } = Astro.props;

const posts = await getCollection("reviews");
const sortedPosts = getSortedPosts(posts);
---

<ReviewDetails post={post} posts={sortedPosts} />
