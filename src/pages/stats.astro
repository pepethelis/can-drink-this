---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import StatsCharts from "@/components/StatsCharts";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import postFilter from "@/utils/postFilter";

const allReviews = await getCollection("reviews", ({ data }) =>
  postFilter({ data })
);
const sorted = getSortedPosts(allReviews);

// ── Summary ───────────────────────────────────────────────────────────────────
const totalReviews = sorted.length;
const favoritesCount = sorted.filter(r => r.data.favorite).length;

const uniqueBrands = new Set(
  sorted
    .map(r => {
      const b = r.data.brand;
      if (!b) return null;
      return b.includes("/") ? b.slice(0, b.indexOf("/")) : b;
    })
    .filter(Boolean)
);
const brandsCount = uniqueBrands.size;

const sponsoredCount = sorted.reduce((count, r) => {
  const sponsors = r.data.sponsor;
  if (!sponsors || sponsors.length === 0) return count;
  return count + sponsors.length;
}, 0);

// ── Category distribution ─────────────────────────────────────────────────────
const catMap = new Map<string, number>();
for (const r of sorted)
  catMap.set(r.data.category, (catMap.get(r.data.category) ?? 0) + 1);
const categoryData: [string, number][] = [...catMap.entries()].sort(
  (a, b) => b[1] - a[1]
);

// ── Type distribution ─────────────────────────────────────────────────────────
const typeMap = new Map<string, number>();
for (const r of sorted)
  for (const t of r.data.types ?? [])
    typeMap.set(t, (typeMap.get(t) ?? 0) + 1);
const typeData: [string, number][] = [...typeMap.entries()].sort(
  (a, b) => b[1] - a[1]
);

// ── Brand distribution (base brands) ─────────────────────────────────────────
const brandMap = new Map<string, number>();
for (const r of sorted) {
  const b = r.data.brand;
  if (!b) continue;
  const base = b.includes("/") ? b.slice(0, b.indexOf("/")) : b;
  brandMap.set(base, (brandMap.get(base) ?? 0) + 1);
}
const brandData: [string, number][] = [...brandMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15);

// ── Reviews over time (gap-filled) ────────────────────────────────────────────
const monthMap = new Map<string, number>();
for (const r of sorted) {
  const d = r.data.publishedAt;
  if (!d) continue;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  monthMap.set(key, (monthMap.get(key) ?? 0) + 1);
}
let timeData: [string, number][] = [];
if (monthMap.size > 0) {
  const keys = [...monthMap.keys()].sort();
  const cur = new Date(keys[0] + "-01");
  const end = new Date(keys[keys.length - 1] + "-01");
  while (cur <= end) {
    const k = `${cur.getFullYear()}-${String(cur.getMonth() + 1).padStart(2, "0")}`;
    timeData.push([k, monthMap.get(k) ?? 0]);
    cur.setMonth(cur.getMonth() + 1);
  }
}

// ── Top tastes ────────────────────────────────────────────────────────────────
const tasteMap = new Map<string, number>();
for (const r of sorted)
  for (const t of r.data.taste ?? [])
    tasteMap.set(t, (tasteMap.get(t) ?? 0) + 1);
const tasteData: [string, number][] = [...tasteMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15);

// ── Container types ───────────────────────────────────────────────────────────
const containerMap = new Map<string, number>();
for (const r of sorted)
  for (const c of r.data.container ?? [])
    containerMap.set(c, (containerMap.get(c) ?? 0) + 1);
const containerData: [string, number][] = [...containerMap.entries()].sort(
  (a, b) => b[1] - a[1]
);

// ── Sweeteners ────────────────────────────────────────────────────────────────
const sweetenerRaw = new Map<string, number>();
for (const r of sorted)
  for (const s of r.data.sweeteners ?? [])
    sweetenerRaw.set(s, (sweetenerRaw.get(s) ?? 0) + 1);

function groupKey(s: string) {
  const l = s.toLowerCase();
  if (l.includes("juice")) return "juice";
  if (l.includes("extract")) return "extract";
  return s;
}

const sweetenerMap = new Map<string, number>();
for (const [s, count] of sweetenerRaw) {
  const key = groupKey(s);
  sweetenerMap.set(key, (sweetenerMap.get(key) ?? 0) + count);
}
const sweetenerData: [string, number][] = [...sweetenerMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12);

// ── Caffeine distribution ─────────────────────────────────────────────────────
const caffeineMap = new Map<string, number>();
for (const r of sorted) {
  const key = r.data.caffeine != null ? `${r.data.caffeine} mg` : "No caffeine";
  caffeineMap.set(key, (caffeineMap.get(key) ?? 0) + 1);
}
const caffeineDistData: [string, number][] = [...caffeineMap.entries()].sort(
  (a, b) => b[1] - a[1]
);

// ── Alcohol distribution ──────────────────────────────────────────────────────
const alcoMap = new Map<string, number>();
for (const r of sorted) {
  const key =
    r.data.alco != null && r.data.alco !== 0 ? `${r.data.alco}%` : "No alcohol";
  alcoMap.set(key, (alcoMap.get(key) ?? 0) + 1);
}
const alcoData: [string, number][] = [...alcoMap.entries()].sort(
  (a, b) => b[1] - a[1]
);

// ── Sponsor distribution ──────────────────────────────────────────────────────
const sponsorMap = new Map<string, number>();
for (const r of sorted) {
  const sponsors = r.data.sponsor;
  if (!sponsors || sponsors.length === 0) continue;
  for (const s of sponsors)
    sponsorMap.set(s, (sponsorMap.get(s) ?? 0) + 1);
}
const sponsorData: [string, number][] = [...sponsorMap.entries()].sort(
  (a, b) => b[1] - a[1]
);

// ── Activity heatmap (daily) ──────────────────────────────────────────────────
const dayMap = new Map<string, number>();
for (const r of sorted) {
  const d = r.data.publishedAt;
  if (!d) continue;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
  dayMap.set(key, (dayMap.get(key) ?? 0) + 1);
}
const activityData: [string, number][] = [...dayMap.entries()].sort((a, b) =>
  a[0].localeCompare(b[0])
);

const reviewsUrl = import.meta.env.BASE_URL.replace(/\/$/, "") + "/reviews";
---

<Layout title={`Stats | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Statistics" pageDesc="Aggregate data across all reviews.">
    <a
      href={reviewsUrl}
      class="mb-6 inline-flex items-center gap-1 text-sm text-foreground/60 hover:text-accent"
    >
      ← All reviews
    </a>

    <!-- Summary cards -->
    <div class="mb-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="rounded-lg bg-muted p-4 text-center">
        <div class="text-3xl font-bold text-accent">{totalReviews}</div>
        <div class="mt-1 text-xs tracking-widest text-foreground/50 uppercase">
          Reviews
        </div>
      </div>
      <div class="rounded-lg bg-muted p-4 text-center">
        <div class="text-3xl font-bold text-accent">{brandsCount}</div>
        <div class="mt-1 text-xs tracking-widest text-foreground/50 uppercase">
          Brands
        </div>
      </div>
      <div class="rounded-lg bg-muted p-4 text-center">
        <div class="text-3xl font-bold text-accent">{favoritesCount}</div>
        <div class="mt-1 text-xs tracking-widest text-foreground/50 uppercase">
          Favorite Drinks
        </div>
      </div>
      <div class="rounded-lg bg-muted p-4 text-center">
        <div class="text-3xl font-bold text-accent">{sponsoredCount}</div>
        <div class="mt-1 text-xs tracking-widest text-foreground/50 uppercase">
          Sponsored Items
        </div>
      </div>
    </div>

    <!-- Charts (React + Recharts) -->
    <StatsCharts
      client:load
      categoryData={categoryData}
      typeData={typeData}
      brandData={brandData}
      timeData={timeData}
      tasteData={tasteData}
      containerData={containerData}
      sweetenerData={sweetenerData}
      caffeineDistData={caffeineDistData}
      alcoData={alcoData}
      activityData={activityData}
      sponsorData={sponsorData}
    />
  </Main>
  <Footer />
</Layout>

<style is:global>
  .chart-card {
    border-radius: 0.5rem;
    background-color: color-mix(in srgb, var(--muted) 40%, transparent);
    padding: 1rem 1.25rem;
  }
  .chart-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--foreground) 45%, transparent);
    margin-bottom: 0.75rem;
  }
</style>
